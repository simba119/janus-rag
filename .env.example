# ============================================
# Janus-RAG 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置
# ============================================

# ---------- 搜索适配器选择 ----------
# 可选: bocha, opencli, agent_reach, static
SEARCH_ADAPTER=bocha

# ---------- 博查 AI 搜索 (默认推荐) ----------
BOCHA_API_KEY=your_bocha_api_key_here

# ---------- OpenCLI 配置 (当 SEARCH_ADAPTER=opencli 时生效) ----------
# OPENCLI_BINARY=opencli

# ---------- Agent-Reach 配置 ----------
# AGENT_REACH_ENDPOINT=http://localhost:3000

# ---------- 模型配置 ----------
# HuggingFace 模型下载镜像（国内必选）
HF_ENDPOINT=https://hf-mirror.com

TEXT_GEN_MODEL=Qwen/Qwen2.5-1.5B-Instruct
VIMRAG_MODEL_NAME=Qwen/Qwen2-VL-7B-Instruct
VIMRAG_DEVICE=cpu

# ---------- 路由与超时 ----------
SEARCH_THRESHOLD=0.7
SEARCH_TIMEOUT=1.5
